                              <body name="finger_1" pos= "-0.016 0.027 -0.00893" euler="0 0 0">
                                <geom type="box" size="0.015 0.005 0.025" pos="0.00 0.015 0.05"
                                  rgba="0 0.0 0 1" contype="1" conaffinity="1"/>
                              </body>
                          </body>
                          <body name="egp_trans_2" pos="0.069 -0.016075 0.10975" quat="0.707107 0 0 -0.707107">
                            <inertial pos="0.0016549 -0.037399 0.0049123" quat="0.816943 0.565095 0.101742 -0.0540342" mass="0.010866" diaginertia="3.59725e-06 3.09617e-06 7.99681e-07"/>
                            <joint name="egp_prismatic_2" pos="0 0 0" axis="0 1 0" type="slide" range="-0.02 0.03" actuatorfrcrange="-300 300" damping="0.3" frictionloss="0.2"/>
                            <geom pos="-0.016 -0.037 -0.00893" quat="1 0 0 0" type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="egp_trans_2"/>
                              <body name="finger_2" pos= "-0.016 -0.037 -0.00893" euler="0 0 0">
                              <geom type="box" size="0.015 0.005 0.025" pos="0.00 -0.015 0.05"
                                rgba="0 0.0 0 1" contype="1" conaffinity="1"/>
                              </body>
                            </body>
                          </body> -->
                        </body>

                    </body><!-- cam_mount_body -->
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

<!-- 
   <contact>
    <exclude body1="egp_trans_1"     body2="egp_trans_2"/>
    
  </contact> -->

  <actuator>
    <motor name="shoulder_pan" joint="shoulder_pan_joint"/>
    <motor  name="shoulder_lift" joint="shoulder_lift_joint"/>
    <motor name="elbow" joint="elbow_joint"/>
    <motor name="wrist_1" joint="wrist_1_joint"/>
    <motor name="wrist_2" joint="wrist_2_joint"/>
    <motor name="wrist_3" joint="wrist_3_joint"/>
    <!-- <general class="size1" name="shoulder_pan_vel"  joint="egp_prismatic_1" />
    <general class="size1" name="shoulder_lift_vel" joint="egp_prismatic_2" /> -->
  </actuator>

  <keyframe>
    <key name="home" qpos="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0" ctrl="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0"/>
  </keyframe>

  
</mujoco>
